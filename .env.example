# Movie Music Matcher 配置文件
# ==============================
# 复制此文件为 .env，然后填入你的 API Key
#   cp .env.example .env    (Mac/Linux)
#   copy .env.example .env  (Windows CMD)
#
# ⚠️ .env 文件包含密钥，不要提交到 Git！

# ---- DeepSeek API (Anthropic 兼容协议) ----
# 在 https://platform.deepseek.com/api_keys 创建 API Key
ANTHROPIC_API_KEY=sk-your-deepseek-api-key-here
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
AI_MODEL=deepseek-chat

# ---- 可选：HuggingFace API (AI 音乐生成) ----
# 在 https://huggingface.co/settings/tokens 创建 Token（免费）
HUGGINGFACE_API_TOKEN=hf_your-token-here

# ---- Git 自动更新（可选）----
# GIT_REMOTE_URL=https://github.com/yourname/movie-music-matcher.git
# GIT_BRANCH=master
